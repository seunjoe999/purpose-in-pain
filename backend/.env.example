# Purpose In Pain Initiative CIC — Backend environment variables
# Copy this file to .env and fill in real values for local development.

NODE_ENV=development
PORT=4000

# ── PostgreSQL ────────────────────────────────────────────────────────────
# A full connection string, e.g.:
# postgresql://postgres:YOUR_PASSWORD@localhost:5432/purpose_in_pain
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/purpose_in_pain
DB_SSL=false

# ── CORS ──────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173

# ── JWT (admin dashboard auth) ───────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-before-deploying

# ── Admin bootstrap (used once by `npm run migrate` to create the first
#    admin_users row; change the password afterwards from the DB if needed) ─
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# ── Paystack ──────────────────────────────────────────────────────────────
# Get TEST keys from https://dashboard.paystack.com/#/settings/developer
# Swap for LIVE keys only when ready to accept real donations.
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_CURRENCY=GBP

# ── Migration behaviour ───────────────────────────────────────────────────
# Set to "false" to skip loading illustrative placeholder events/blog posts.
SEED_ON_MIGRATE=true

# ── Email delivery (SMTP) ─────────────────────────────────────────────────
# Optional. If unset, forms still work — submissions are always saved to
# Postgres and visible in the admin dashboard — but no notification/receipt
# emails are sent (a warning is logged instead).
#
# Works with any standard SMTP provider. For Gmail (purposeinpain1@gmail.com):
#   1. Enable 2-Step Verification on the Google account
#   2. Create an "App Password" at https://myaccount.google.com/apppasswords
#   3. Use that 16-character app password as SMTP_PASS below (not the normal
#      account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=purposeinpain1@gmail.com
SMTP_PASS=
# Inbox that contact-form and volunteer-signup notifications are sent to.
# Defaults to purposeinpain1@gmail.com if unset.
NOTIFICATION_EMAIL=purposeinpain1@gmail.com
# "From" address used on outgoing mail (defaults to SMTP_USER if unset).
SMTP_FROM=purposeinpain1@gmail.com
