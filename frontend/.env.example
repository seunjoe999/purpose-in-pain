# Purpose In Pain Initiative CIC — Frontend environment variables
# Copy this file to .env.local for local development (Vite auto-loads it).

# Leave unset in local dev — vite.config.ts proxies /api to the backend on :4000.
# Set this only when the frontend is deployed separately from the backend.
# VITE_API_BASE_URL=http://localhost:4000/api

# NOTE: The Donate page uses Paystack's server-initiated "Standard Checkout"
# redirect flow (backend calls /transaction/initialize with the SECRET key and
# the browser is redirected to the returned authorization_url). Because of
# this, no Paystack PUBLIC key is required in the frontend for the current
# implementation. If you later switch to Paystack Inline JS (popup checkout
# instead of redirect), add VITE_PAYSTACK_PUBLIC_KEY here.
